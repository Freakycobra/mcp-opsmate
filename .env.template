# =============================================================================
# mcp-opsmate — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your credentials for LIVE mode.
# MOCK mode works with zero configuration — just run `docker compose up -d`.
# =============================================================================

# ------------------------------------------------------------------------------
# Application Mode
# ------------------------------------------------------------------------------
# mock  = Use mock data for all integrations (default, no credentials needed)
# live  = Use real API keys for configured integrations
OPSMATE_MODE=mock

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_USER=opsmate
POSTGRES_PASSWORD=opsmate
POSTGRES_DB=opsmate
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Cache (Redis)
# ------------------------------------------------------------------------------
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Nginx
# ------------------------------------------------------------------------------
NGINX_PORT=8080

# ------------------------------------------------------------------------------
# Prometheus (optional — use with --profile monitoring)
# ------------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# ------------------------------------------------------------------------------
# Tavily Search (LIVE mode only — optional)
# Get your API key at: https://tavily.com/
# ------------------------------------------------------------------------------
# TAVILY_API_KEY=your_tavily_api_key_here

# ------------------------------------------------------------------------------
# GitHub (LIVE mode only — optional)
# Create a token at: https://github.com/settings/tokens
# ------------------------------------------------------------------------------
# GITHUB_TOKEN=your_github_token_here

# ------------------------------------------------------------------------------
# Slack (LIVE mode only — optional)
# Create a bot at: https://api.slack.com/apps
# ------------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ------------------------------------------------------------------------------
# Jira (LIVE mode only — optional)
# ------------------------------------------------------------------------------
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token

# ------------------------------------------------------------------------------
# AWS (always MOCK via LocalStack by default)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# ------------------------------------------------------------------------------
# LocalStack (optional — use with --profile aws)
# ------------------------------------------------------------------------------
# LOCALSTACK_SERVICES=s3,ec2,iam,cloudformation
# LOCALSTACK_DEBUG=0
