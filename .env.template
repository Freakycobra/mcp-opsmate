# =============================================================================
# mcp-opsmate — Environment Configuration
# =============================================================================
# MOCK mode works with zero configuration — just run `docker compose up -d`.
# Uncomment and fill lines below to enable LIVE mode for specific integrations.
# =============================================================================

# ------------------------------------------------------------------------------
# Application Mode
# ------------------------------------------------------------------------------
# mock = Use mock data for all integrations (default, no credentials needed)
# live = Use real API keys for configured integrations
OPSMATE_MODE=mock

# ------------------------------------------------------------------------------
# OpenAI (REQUIRED — used for intent classification even in mock mode)
# Get your key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------------------
# Tavily Search (optional — for web search in LIVE mode)
# Get your key at: https://tavily.com/
# ------------------------------------------------------------------------------
# TAVILY_API_KEY=your_tavily_api_key_here

# ------------------------------------------------------------------------------
# GitHub (optional — for repo/CI info in LIVE mode)
# Create a token at: https://github.com/settings/tokens (scopes: repo, workflow)
# ------------------------------------------------------------------------------
# GITHUB_PAT=your_github_pat_here

# ------------------------------------------------------------------------------
# Slack (optional — for alerts in LIVE mode)
# Create an incoming webhook at: https://api.slack.com/apps
# ------------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ------------------------------------------------------------------------------
# Jira (optional — for ticket operations in LIVE mode)
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# ------------------------------------------------------------------------------
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token_here

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database (PostgreSQL) — only change if you have port conflicts
# ------------------------------------------------------------------------------
POSTGRES_USER=opsmate
POSTGRES_PASSWORD=opsmate
POSTGRES_DB=opsmate
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Cache (Redis) — only change if you have port conflicts
# ------------------------------------------------------------------------------
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Nginx — only change if you have port conflicts
# ------------------------------------------------------------------------------
NGINX_PORT=8080

# ------------------------------------------------------------------------------
# AWS (always MOCK via LocalStack — no real credentials needed)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
